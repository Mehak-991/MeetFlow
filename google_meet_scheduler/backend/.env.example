# Database Configuration (PostgreSQL URL or SQLite fallback)
DATABASE_URL=postgresql://user:password@localhost:5432/MeetFlow

# Google OAuth 2.0 Credentials (Get these from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# JWT Configurations (Strong random 32-character string)
JWT_SECRET=your_super_secret_jwt_token_key_here

# CORS Configurations
FRONTEND_URL=http://localhost:3000

# Server Port Configurations
PORT=8000
